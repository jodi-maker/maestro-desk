# Secrets — never commit real env files (only .env.example is tracked)
.env
.env.*
!.env.example
api/.env
api/.env.*
!api/.env.example

# Supabase CLI scratch — local-only project link metadata. The supabase/
# directory is retired, but this guards against re-creation if the CLI is
# ever run again (it writes a project ref + pooler URL here).
supabase/.temp/

