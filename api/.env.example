# Supabase — from https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://zpqapvffhakkbyadfcpr.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Neon Postgres — migration to Neon (Step 1). Get this from the Neon
# dashboard: project → Connection Details → copy the connection string.
# Use the "dev" branch's string while building. Keep ?sslmode=require.
# Format: postgresql://user:pass@ep-xxxx.<region>.aws.neon.tech/maestro-desk?sslmode=require
DATABASE_URL=

# Better Auth — the live auth system (Step 3 cutover). Owns sign-in/sessions/users.
# SECRET signs sessions/tokens — generate with `openssl rand -base64 32`.
# REQUIRED: the app will not boot without it.
# URL is the API's own base URL where Better Auth serves /api/auth/*.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Public origin of the agent SPA (where index.html is served). Trusted origin
# for Better Auth, and the base of the password-reset link emailed to invited
# users. Dev = the local static server; set to https://desk.maestro-desk.com
# in prod.
APP_BASE_URL=http://localhost:5173

# Anthropic — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Postmark inbound webhook — shared secret passed as ?secret=... query string
# on the webhook URL configured in Postmark's dashboard. Min 16 chars. Generate
# one in PowerShell with:
#   [Convert]::ToBase64String([byte[]](1..24 | %{Get-Random -Max 256}))
POSTMARK_INBOUND_SECRET=CHANGE_ME_pick_a_long_random_string

# Postmark outbound — used to send auto-replies back to customers.
#   1. In Postmark, create (or pick) a Server. Each Server has its own
#      Server API Token (Settings → API Tokens). Copy it into
#      POSTMARK_SERVER_TOKEN below.
#   2. Add a Sender Signature for the address you'll send from
#      (Sender Signatures → Add). Verify the email Postmark sends. For
#      production, verify a domain (DKIM + Return-Path) instead.
#   3. Put the verified address in POSTMARK_OUTBOUND_FROM. The display name
#      shown to customers is the workspace name (not configured here).
# Send uses the default 'outbound' transactional stream.
POSTMARK_SERVER_TOKEN=
POSTMARK_OUTBOUND_FROM=
# Postmark inbound stream address — set as Reply-To on outbound auto-replies
# so customer replies come back through the webhook. Find under Postmark →
# Servers → <your server> → Default Inbound Stream → Settings (the "To"
# address at the top, ending in @inbound.postmarkapp.com).
POSTMARK_INBOUND_REPLY_ADDRESS=

# Public-facing portal URL. Used to build links embedded in customer
# emails — CSAT surveys, CSAT reminders, magic-link sign-in fallback.
# Should include the protocol and the path to portal.html, e.g.
#   https://help.acme.com/portal.html
# Leave empty in dev: csat code falls back to http://localhost:5173/
# portal.html and the magic-link path derives from the request origin.
PORTAL_BASE_URL=

# Cloudflare R2 — migration to Neon (Step 4). Stores brand-asset uploads
# (workspace logos), replacing Supabase Storage. R2 speaks the S3 API.
#   1. Cloudflare dashboard → R2 → create a bucket named "brand-assets".
#   2. R2 → Manage R2 API Tokens → Create API Token (Object Read & Write,
#      scoped to that bucket). Copy the Access Key ID + Secret Access Key.
#   3. R2_ACCOUNT_ID is your Cloudflare account ID (R2 overview page); it
#      forms the endpoint host <account-id>.r2.cloudflarestorage.com.
#   4. PUBLIC_BASE_URL: enable the bucket's public r2.dev URL (Settings →
#      Public Development URL) OR connect a custom domain, and paste the
#      base here WITHOUT a trailing slash, e.g.
#        https://pub-xxxxxxxx.r2.dev   or   https://assets.maestro-desk.com
#      The stored logo_url is `${PUBLIC_BASE_URL}/${workspaceId}/logo-...`.
# Leave empty in dev; logo upload returns a clear error until configured.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=brand-assets
R2_PUBLIC_BASE_URL=

# Local dev
PORT=3001
