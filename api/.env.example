# Supabase — from https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://zpqapvffhakkbyadfcpr.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Postmark inbound webhook — shared secret passed as ?secret=... query string
# on the webhook URL configured in Postmark's dashboard. Min 16 chars. Generate
# one in PowerShell with:
#   [Convert]::ToBase64String([byte[]](1..24 | %{Get-Random -Max 256}))
POSTMARK_INBOUND_SECRET=CHANGE_ME_pick_a_long_random_string

# Postmark outbound — used to send auto-replies back to customers.
#   1. In Postmark, create (or pick) a Server. Each Server has its own
#      Server API Token (Settings → API Tokens). Copy it into
#      POSTMARK_SERVER_TOKEN below.
#   2. Add a Sender Signature for the address you'll send from
#      (Sender Signatures → Add). Verify the email Postmark sends. For
#      production, verify a domain (DKIM + Return-Path) instead.
#   3. Put the verified address in POSTMARK_OUTBOUND_FROM. The display name
#      shown to customers is the workspace name (not configured here).
# Send uses the default 'outbound' transactional stream.
POSTMARK_SERVER_TOKEN=
POSTMARK_OUTBOUND_FROM=
# Postmark inbound stream address — set as Reply-To on outbound auto-replies
# so customer replies come back through the webhook. Find under Postmark →
# Servers → <your server> → Default Inbound Stream → Settings (the "To"
# address at the top, ending in @inbound.postmarkapp.com).
POSTMARK_INBOUND_REPLY_ADDRESS=

# Public-facing portal URL. Used to build links embedded in customer
# emails — CSAT surveys, CSAT reminders, magic-link sign-in fallback.
# Should include the protocol and the path to portal.html, e.g.
#   https://help.acme.com/portal.html
# Leave empty in dev: csat code falls back to http://localhost:5173/
# portal.html and the magic-link path derives from the request origin.
PORTAL_BASE_URL=

# Local dev
PORT=3001
