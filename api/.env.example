# Neon Postgres — the source of truth. Get this from the Neon dashboard:
# project → Connection Details → copy the connection string. Keep
# ?sslmode=require. Required — the API will not boot without it.
# Format: postgresql://user:pass@ep-xxxx.<region>.aws.neon.tech/maestro-desk?sslmode=require
DATABASE_URL=

# Better Auth — the live auth system (Step 3 cutover). Owns sign-in/sessions/users.
# SECRET signs sessions/tokens — generate with `openssl rand -base64 32`.
# REQUIRED: the app will not boot without it.
# URL is the API's own base URL where Better Auth serves /api/auth/*.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Public origin of the agent SPA (where index.html is served). Trusted origin
# for Better Auth, and the base of the password-reset link emailed to invited
# users. Dev = the local static server; set to https://desk.maestro-desk.com
# in prod.
APP_BASE_URL=http://localhost:5173

# Anthropic — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Postmark inbound webhook — shared secret passed as ?secret=... query string
# on the webhook URL configured in Postmark's dashboard. Min 16 chars. Generate
# one in PowerShell with:
#   [Convert]::ToBase64String([byte[]](1..24 | %{Get-Random -Max 256}))
POSTMARK_INBOUND_SECRET=CHANGE_ME_pick_a_long_random_string

# Postmark outbound — used to send auto-replies back to customers.
#   1. In Postmark, create (or pick) a Server. Each Server has its own
#      Server API Token (Settings → API Tokens). Copy it into
#      POSTMARK_SERVER_TOKEN below.
#   2. Add a Sender Signature for the address you'll send from
#      (Sender Signatures → Add). Verify the email Postmark sends. For
#      production, verify a domain (DKIM + Return-Path) instead.
#   3. Put the verified address in POSTMARK_OUTBOUND_FROM. The display name
#      shown to customers is the workspace name (not configured here).
# Send uses the default 'outbound' transactional stream.
POSTMARK_SERVER_TOKEN=
POSTMARK_OUTBOUND_FROM=
# Postmark Account API Token (Postmark UI → Account → API Tokens). REQUIRED
# for the Postmark Domains API — provisioning per-brand white-label sender
# domains. Distinct from POSTMARK_SERVER_TOKEN above: that one is per-server
# (sending mail); this one is per-account (managing senders + domains). When
# empty, adding a brand domain still creates the local workspace_email_domains
# row but skips Postmark provisioning; the brand can re-trigger verification
# via POST /api/v1/god/brands/:id/domains/:domainId/verify once configured.
POSTMARK_ACCOUNT_TOKEN=
# Postmark inbound stream address — set as Reply-To on outbound auto-replies
# so customer replies come back through the webhook. Find under Postmark →
# Servers → <your server> → Default Inbound Stream → Settings (the "To"
# address at the top, ending in @inbound.postmarkapp.com).
POSTMARK_INBOUND_REPLY_ADDRESS=

# Public-facing portal URL. Used to build links embedded in customer
# emails — CSAT surveys, CSAT reminders, magic-link sign-in fallback.
# Should include the protocol and the path to portal.html, e.g.
#   https://help.acme.com/portal.html
# Leave empty in dev: csat code falls back to http://localhost:5173/
# portal.html and the magic-link path derives from the request origin.
PORTAL_BASE_URL=

# Cloudflare R2 — migration to Neon (Step 4). Stores brand-asset uploads
# (workspace logos), replacing Supabase Storage. R2 speaks the S3 API.
#   1. Cloudflare dashboard → R2 → create a bucket named "brand-assets".
#   2. R2 → Manage R2 API Tokens → Create API Token (Object Read & Write,
#      scoped to that bucket). Copy the Access Key ID + Secret Access Key.
#   3. R2_ACCOUNT_ID is your Cloudflare account ID (R2 overview page); it
#      forms the endpoint host <account-id>.r2.cloudflarestorage.com.
#   4. PUBLIC_BASE_URL: enable the bucket's public r2.dev URL (Settings →
#      Public Development URL) OR connect a custom domain, and paste the
#      base here WITHOUT a trailing slash, e.g.
#        https://pub-xxxxxxxx.r2.dev   or   https://assets.maestro-desk.com
#      The stored logo_url is `${PUBLIC_BASE_URL}/${workspaceId}/logo-...`.
# Leave empty in dev; logo upload returns a clear error until configured.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=brand-assets
R2_PUBLIC_BASE_URL=

# Pubby realtime — migration Step 5. Pusher-compatible push for live ticket
# updates. From your Pubby app dashboard (app.pubby.dev). All optional: when
# unset, realtime is disabled and the SPA falls back to polling.
#   APP_ID/KEY/SECRET — the app credentials (KEY is the public app key the SPA
#     also uses; SECRET signs triggers + channel auth, server-only).
#   WS_HOST — the client WebSocket host, e.g. wss://ws.pubby.dev
#   API_HOST — optional; defaults to https://api.pubby.dev (where triggers POST)
PUBBY_APP_ID=
PUBBY_KEY=
PUBBY_SECRET=
PUBBY_WS_HOST=
PUBBY_API_HOST=

# Vercel Cron secret — migration Step 6. Vercel sends this as a bearer token
# when invoking /api/v1/cron/*; the endpoints reject anything else. Set on
# Vercel (openssl rand -base64 32). Leave empty locally (the in-process worker
# in src/dev.ts handles sweeps; the cron endpoints stay closed without it).
CRON_SECRET=

# Local dev
PORT=3001

# Maestro Connect — platform integration (app "Service Desk").
# Sign-in: credentials from `maestro apps create` / developers.mert.md →
# Apps → Service Desk. Empty = "Sign in with Maestro" disabled.
MAESTRO_CLIENT_ID=
MAESTRO_CLIENT_SECRET=
# Headless worker (email pipeline player-context for AI drafts): mint an
# mh_live_* token AFTER the app is approved (portal → Apps → Tokens), and
# set the default brand id from `maestro apps installations <appId>`.
# Empty = AI drafts simply skip player enrichment.
MAESTRO_API_TOKEN=
MAESTRO_BRAND_ID=
# Defaults are correct for production Maestro; override only for a sandbox.
# MAESTRO_ISSUER=https://auth.mert.md
# MAESTRO_GATEWAY_URL=https://api.mert.md

# ─── Sentry error tracking (observability) ───────────────────────────────────
# Optional. Leave SENTRY_DSN empty and the app behaves exactly as before —
# lib/instrument.ts skips Sentry.init, so capture + flush no-op. Set the DSN
# (Sentry project → Settings → Client Keys) in the Vercel Production env to
# turn on error reporting; no code change needed.
SENTRY_DSN=
# Optional event tag; falls back to VERCEL_ENV (production/preview) then
# 'development' when unset.
SENTRY_ENVIRONMENT=

# ─── Live ops alerts (lib/alert.ts) ──────────────────────────────────────────
# Pushed when something critical happens: an audit-chain tamper, an unhandled
# API error, or a failed cron. Two independent channels — set either, both, or
# neither (alerts always also go to the server logs).
# Email: also needs POSTMARK_SERVER_TOKEN + POSTMARK_OUTBOUND_FROM (above).
ALERT_EMAIL_TO=
# Slack: an Incoming Webhook URL (Slack → your app → Incoming Webhooks → Add
# New Webhook to Workspace). Looks like https://hooks.slack.com/services/...
SLACK_ALERT_WEBHOOK_URL=

# ─── Web Push (offline-agent notifications) ───────────────────────────────
# Generate the keypair once with: npx web-push generate-vapid-keys
# All optional: unset → push no-ops and the SPA hides the opt-in.
# VAPID_PUBLIC_KEY is exposed to the browser (via GET /push/config); keep the
# PRIVATE key server-only. SUBJECT is a mailto: or https: contact URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@maestro-desk.com
