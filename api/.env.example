# Supabase — from https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://zpqapvffhakkbyadfcpr.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Postmark inbound webhook — shared secret passed as ?secret=... query string
# on the webhook URL configured in Postmark's dashboard. Min 16 chars. Generate
# one in PowerShell with:
#   [Convert]::ToBase64String([byte[]](1..24 | %{Get-Random -Max 256}))
POSTMARK_INBOUND_SECRET=CHANGE_ME_pick_a_long_random_string

# Local dev
PORT=3001
